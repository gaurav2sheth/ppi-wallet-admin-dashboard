# PPI Wallet — Admin Dashboard (admin-dashboard)
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env`.

# Backend API URL (optional — defaults to '' which triggers mock mode)
VITE_API_URL=

# Admin dashboard demo credentials (DEMO MODE ONLY — see docs/security.md §Auth)
#
# NOTE: These variables are scaffolding for a future env-var-driven auth
# flow. Today's demo code still uses hardcoded fallback credentials in
# src/store/auth.store.ts for GitHub Pages compatibility. Replacing those
# with env-var reads is a documented gap in docs/scope-and-limitations.md.
#
# Pick fresh values here; do not reuse real production passwords.

VITE_DEMO_ADMIN_USERNAME=admin
VITE_DEMO_ADMIN_PASSWORD=change-me-in-env

VITE_DEMO_BUSINESS_USERNAME=business
VITE_DEMO_BUSINESS_PASSWORD=change-me-in-env

VITE_DEMO_SUPPORT_USERNAME=support
VITE_DEMO_SUPPORT_PASSWORD=change-me-in-env
